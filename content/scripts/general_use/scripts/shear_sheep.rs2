[opnpcu,sheepsheered]
if(last_useitem = shears) {
    mes("This sheep has already been shorn.");
    return;
}
~displaymessage(^dm_default);

[opnpcu,sheep_shearer_the_thing]
if(last_useitem ! shears) {
    ~displaymessage(^dm_default);
    return;
}
@the_thing_shear;

[opnpc1,sheep_shearer_the_thing]
if(inv_total(inv, shears) < 1) {
    // mes sourced from 2025 OSRS
    // regular sheep say "You need a set of shears to do this."
    mes("You need a pair of shears to do this.");
    return;
}
@the_thing_shear;

[label,the_thing_shear]
%the_thing_sheared = 1;
anim(human_shearing, 0);
sound_synth(shear_sheep, 0, 0);
// the thing's anim seems to happen one tick later in OSRS?
npc_anim(the_thing_shear, 0);
mes("The... whatever it is... manages to get away from you!");
npc_setmode(playerescape);
