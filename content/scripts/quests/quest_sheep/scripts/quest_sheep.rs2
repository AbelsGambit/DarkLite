[queue,sheep_complete]
%sheep = ^sheep_complete;
inv_del(inv, ball_of_wool, 1);
inv_add(inv, coins, 60);
stat_advance(crafting, 1500);
session_log(^log_adventure, "Quest complete: Sheep Shearer");
~send_quest_complete(questlist:sheep, shears, 250, ^sheep_questpoints, "You have completed the Sheep Shearer Quest!", "150 Crafting XP|60 coins");
