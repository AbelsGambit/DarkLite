[label,levelrequire_iban_staff](int $slot)
// https://youtu.be/FKFdDdH5rlE?si=rTj214wpX9RKHiMy&t=188
if (stat_base(magic) < 50) {
    mes("You are not a high enough level to use this item,");
    mes("You need to have a Magic level of 50.");
    return;
}
if (stat_base(attack) < 50) {
    mes("You are not a high enough level to use this item.");
    mes("You need to have an Attack level of 50.");
    return;
}
~equip($slot);

[label,levelrequire_prayer](int $level, int $slot)
if (stat_base(prayer) < $level) {
