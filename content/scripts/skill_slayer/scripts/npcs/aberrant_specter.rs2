[ai_queue1,_slayer_aberrant_specter] gosub(npc_default_retaliate_ap);
[ai_applayer2,_slayer_aberrant_specter]
~aberrant_attack;

[ai_opplayer2,_slayer_aberrant_specter]
~aberrant_attack;

[proc,aberrant_attack]
if (stat(hitpoints) = 0) { // no idea if this should exist
    return;
}
if (%npc_action_delay > map_clock) {
    npc_setmode(applayer2);
    return;
}
if (~npc_check_notcombat = false) {
    npc_setmode(null);
    return;
}
if (~npc_check_notcombat_self = false) {
    return;
}
if_close;
npc_anim(specter_attack, 0);
spotanim_npc(specter_goo_launch, 500, 0); // 500 is correct
sound_synth(slayerdoors_close, 0, 0);
%npc_action_delay = add(map_clock, 4);
def_int $duration = ~player_projectile(npc_coord, coord, uid, specter_goo_travel, 61, 40, 32, 5, 0, 4, 10);
def_int $maxhit = 8;
def_int $damage = randominc($maxhit);
if(inv_total(worn, slayer_nosepeg) = 0) {
    $damage = 14; // un-protectable
    // reduction is 20% (current) for att/str/range/mage, 10% on def and prayer
    // stat reduction isnt queued
    stat_drain(attack, 0, 80);
    stat_drain(strength, 0, 80);
    stat_drain(ranged, 0, 80);
    stat_drain(magic, 0, 80);
    stat_drain(agility, 0, 40);
    stat_drain(defence, 0, 40);
    stat_drain(prayer, 0, 40);
}
if (~npc_player_hit_roll(^magic_style) = true | inv_total(worn, slayer_nosepeg) = 0) {
    queue(combat_damage_player, calc($duration / 30), $damage);
} else {
    queue(combat_damage_player, calc($duration / 30), 0);
}
spotanim_pl(specter_goo_impact, 320, $duration);
sound_synth(goo_hit, 0, $duration);
queue*(playerhit_n_retaliate, calc($duration / 30))(npc_uid);
