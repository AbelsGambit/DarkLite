[oploc1,elenadoor2]
switch_int(%elenaquest) {
    case ^elena_complete, ^elena_complete_read_scroll :
        ~open_and_close_door2(loc_param(next_loc_stage), ~check_axis(coord, loc_coord, loc_angle), door_open);
        if (coord = loc_coord & npc_find(coord, elena2_vis, 20, 0) = false) {
            @spawn_elena;
        }
    case default : mes("The door is locked.");
}

[label,spawn_elena]
if (%elenaquest >= ^elena_complete) {
    npc_add(0_40_52_31_9, elena2_vis, 200);
}
