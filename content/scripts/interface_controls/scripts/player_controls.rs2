// @controls_emote(bunny_hop);

[label,controls_emote](seq $anim)
if_close;
if (p_finduid(uid) = false) {
    return;
}
p_stopaction;
anim($anim, 20);

[label,lockemote_mime_event]
~mesbox("This emote can be unlocked during the mime random event.");

[label,lockemote_gravedigger_event]
~mesbox("This emote can be unlocked during the gravedigger random event.");

[label,lockemote_lost_tribe]
~mesbox("This emote can be unlocked during the Lost Tribe quest.");
