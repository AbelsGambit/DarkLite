[proc,book](string $title, string $string)
split_init($string, 175, 22, q8_full);
def_int $page = 0;
def_int $pagetotal = split_pagecount;
while ($page < $pagetotal) {
    ~book_page($title, $page);
    $page = calc($page + 1);
}

[proc,book_page](string $title, int $page)
if_settext(book:com_88, split_get($page, 0));
if_settext(book:com_89, split_get($page, 1));
if_settext(book:com_90, split_get($page, 2));
if_settext(book:com_91, split_get($page, 3));
if_settext(book:com_92, split_get($page, 4));
if_settext(book:com_93, split_get($page, 5));
if_settext(book:com_94, split_get($page, 6));
if_settext(book:com_95, split_get($page, 7));
if_settext(book:com_96, split_get($page, 8));
if_settext(book:com_97, split_get($page, 9));
if_settext(book:com_98, split_get($page, 10));
if_settext(book:com_99, split_get($page, 11));
if_settext(book:com_100, split_get($page, 12));
if_settext(book:com_101, split_get($page, 13));
if_settext(book:com_102, split_get($page, 14));
if_settext(book:com_103, split_get($page, 15));
if_settext(book:com_104, split_get($page, 16));
if_settext(book:com_105, split_get($page, 17));
if_settext(book:com_106, split_get($page, 18));
if_settext(book:com_107, split_get($page, 19));
if_settext(book:com_108, split_get($page, 20));
if_settext(book:com_109, split_get($page, 21));
if_settext(book:book_title, $title);
if_settext(book:com_110, ""); // Set page number to blank (left side) - Not used until way past 377
if_settext(book:com_111, ""); // Set page number to blank (right side) - Not used until way past 377
if_openmain(book);

[label,book_flip_page](int $page_direction, int $min_page, int $max_page, proc $proc)
%book_page = add(%book_page, $page_direction);
if (%book_page > $max_page) {
    %book_page = $max_page;
} else if (%book_page < $min_page) {
    %book_page = $min_page;
}

if (%book_page = $min_page) {
    if_sethide(book:com_85, true);
} else {
    if_sethide(book:com_85, false);
}

if (%book_page = $max_page) {
    if_sethide(book:com_87, true);
} else {
    if_sethide(book:com_87, false);
}

//if_settext(book:com_110, "<tostring(add(multiply(%book_page, 2), 1))>"); // Update page number display (left side) - Not used until way past 377
//if_settext(book:com_111, "<tostring(add(multiply(%book_page, 2), 2))>"); // Update page number display (right side) - Not used until way past 377

gosub($proc);
