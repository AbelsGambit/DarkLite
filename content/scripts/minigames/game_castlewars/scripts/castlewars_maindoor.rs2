[proc,castle_wars_door_try_repair](int $team)(boolean)
if ($team ! %castlewars_team) {
    mes("You don't want to repair your opponents door.");
    return(false);
}
if (inv_total(inv, castlewars_toolkit) < 1) {
    mes("You need a toolkit to repair the doors.");
    return(false);
}
~castlewars_door_damage(%castlewars_team, -100);
return(true);

// You need a toolkit to repair the doors.
// You don't want to repair your opponents door.

[oploc1,castlewars_saradomin_maindoorr_open] ~close_double_doors_right(500, door_left_open, loc_param(close_sound));
[oploc1,castlewars_saradomin_maindoorl_open] ~close_double_doors_left(500, door_right_open, loc_param(close_sound));
[oploc1,castlewars_zamorak_maindoorr_open] ~close_double_doors_right(500, door_left_open, loc_param(close_sound));
[oploc1,castlewars_zamorak_maindoorl_open] ~close_double_doors_left(500, door_right_open, loc_param(close_sound));
