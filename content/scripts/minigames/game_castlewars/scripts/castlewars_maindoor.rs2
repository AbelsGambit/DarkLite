[proc,castlewars_saradomin_door_health]()(int)
return(sub(100, getbit_range(%castlewars_saradomin_bits, ^castlewars_maindoor_startbit, ^castlewars_maindoor_startbit)));

[proc,castlewars_zamorak_door_health]()(int)
return(sub(100, getbit_range(%castlewars_zamorak_bits, ^castlewars_maindoor_startbit, ^castlewars_maindoor_endbit)));

[proc,castlewars_door_damage](int $team, int $damage)
def_int $total_damage;
if ($team = ^castlewars_team_saradomin) {
    $total_damage = max(min(add(getbit_range(%castlewars_saradomin_bits, ^castlewars_maindoor_startbit, ^castlewars_maindoor_startbit), $damage), 100), 0);
    %castlewars_saradomin_bits = setbit_range_toint(%castlewars_saradomin_bits, $total_damage, ^castlewars_maindoor_startbit, ^castlewars_maindoor_startbit);
} else if ($team = ^castlewars_team_zamorak) {
    $total_damage = max(min(add(getbit_range(%castlewars_zamorak_bits, ^castlewars_maindoor_startbit, ^castlewars_maindoor_endbit), $damage), 100), 0);
    %castlewars_zamorak_bits = setbit_range_toint(%castlewars_zamorak_bits, $total_damage, ^castlewars_maindoor_startbit, ^castlewars_maindoor_endbit);
}
// mes(tostring($damage));
// say("<tostring($damage)>, <tostring($before)>, <tostring($after)>... <tostring($health)>");

[proc,castlewars_attack_door](int $team)(boolean)
if (%castlewars_team = $team) {
    mes("You don't want to damage your own doors."); // 2007
    return(false);
}
if (~check_axis_locactive(coord) = false) {
    mes("You could just open it..."); // 2007
    return(false);
}
p_oploc(2);
facesquare(~movecoord_indirection(coord, modulo(add(loc_angle, 3), 4), 1));
if (%action_delay > map_clock) {
    return(false);
}
def_obj $rhand = inv_getobj(worn, ^wearpos_rhand);
if ($rhand = null) {
    %action_delay = add(map_clock, 4);
} else {
    %action_delay = add(map_clock, oc_param($rhand, attackrate));
}
if (%damagestyle = ^style_ranged_rapid) {
    %action_delay = sub(%action_delay, 1);
}
// doesnt use spotanim/proj for range! player_combat_stat should handle max hit logic
// Also means it doesnt check for ammo, so you can literally be at 0 ammo and you can still range the door!
if (%com_attackanim ! null) anim(%com_attackanim, 0);
if (%com_attacksound ! null) sound_synth(%com_attacksound, 0, 0);
def_int $damage = 0;
if (~castlewars_door_roll = true) {
    // 0 crush at (6 max hit):
    // - 0%: 164
    // - 1%: 156
    // - 2%: 54
    // The above suggests that $damage is rolled *first*, and then the scaling is applied.
    // 2%'s should only happen 1/7 of the time when you land a 6 within 0-6
    $damage = randominc(%com_maxhit);
    switch_int (%damagetype) {
        case ^stab_style : $damage = scale($damage, 100, 25); // osrs: 12 -> 3, 11 -> 2
        case ^crush_style : $damage = scale($damage, 100, 35); // osrs: 17 -> 5, 18 -> 6
        case ^slash_style : $damage = scale($damage, 100, 50); // osrs: 24 -> 12, 23 -> 11
        case ^ranged_style : $damage = scale($damage, 100, 35); // osrs: 17 -> 5, 18 -> 6
    }
}
~castlewars_door_damage($team, $damage);
return(true);

[proc,castlewars_door_roll]()(boolean)
def_int $effective_defence = ~combat_effective_stat(1, 100); // guess
$effective_defence = add($effective_defence, 9); // guess
def_int $defence_roll = ~combat_stat($effective_defence, 0); // guess

def_int $attack_roll = ~player_attack_roll_specific(%damagetype);
if (randominc($attack_roll) > randominc($defence_roll)) {
    return(true);
}
return(false);

