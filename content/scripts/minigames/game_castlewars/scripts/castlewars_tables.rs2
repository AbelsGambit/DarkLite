[oploc1,castlewars_table_bandages]
if (inv_freespace(inv) = 0) {
    ~mesbox("Your inventory is too full to hold any more bandages.");
    return;
}
inv_add(inv, castlewars_bandages, 1);
sound_synth(pick2, 0, 0);
anim(null, 0);

