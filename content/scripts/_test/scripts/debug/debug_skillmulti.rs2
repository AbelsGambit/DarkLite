[debugproc,skill]
if (p_finduid(uid) = false) {
    return;
}
def_obj $obj;
def_int $int;
$obj, $int = ~skillmulti1(rune_kiteshield);

mes("<oc_debugname($obj)>, <tostring($int)>");

