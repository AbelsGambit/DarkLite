+/**
+ * Search for "Tormented Demon" in npc.dat to find its actual ID in this cache.
+ * Also scan the first few NPC configs to check the string terminator format.
+ */
+import FlatFileCacheReader from '#/cache/osrs/FlatFileCacheReader.js';
+
+const reader = new FlatFileCacheReader('data/osrs-cache-flat');
+const result = reader.readArchive(2, 9);
+if (!result) {
+    console.error('Failed to split npc.dat');
+    process.exit(1);
+}
+
+// Search every NPC config for "Tormented" substring
+const search = Buffer.from('Tormented', 'ascii');
+let found = 0;
+for (const [npcId, buf] of result.children) {
+    if (buf.length < search.length) continue;
+    for (let i = 0; i <= buf.length - search.length; i++) {
+        let match = true;
+        for (let j = 0; j < search.length; j++) {
+            if (buf[i + j] !== search[j]) { match = false; break; }
+        }
+        if (match) {
+            console.log(`NPC ${npcId}: contains "Tormented" at offset ${i}`);
+            console.log(`  Context: ${Array.from(buf.slice(Math.max(0, i - 4), Math.min(buf.length, i + 30))).map(b => b.toString(16).padStart(2, '0')).join(' ')}`);
+            console.log(`  ASCII: ${Buffer.from(buf.slice(Math.max(0, i - 4), Math.min(buf.length, i + 30))).toString('ascii').replace(/[^\x20-\x7e]/g, '.')}`);
+            found++;
+            if (found > 20) break;
+        }
+    }
+    if (found > 20) break;
+}
+console.log(`\nTotal NPCs containing "Tormented": ${found}`);
+
+// Check the string terminator format by looking at NPC 0 (Hans)
+console.log('\n=== Checking string terminator on NPC 0 ===');
+const npc0 = result.children.get(0);
+if (npc0) {
+    console.log(`NPC 0: ${npc0.length} bytes`);
+    console.log(`  hex: ${Array.from(npc0.slice(0, 40)).map(b => b.toString(16).padStart(2, '0')).join(' ')}`);
+    // Find opcode 2 (name) — scan for it
+    let pos = 0;
+    while (pos < npc0.length) {
+        const op = npc0[pos];
+        if (op === 2) {
+            console.log(`  Found op 2 (name) at offset ${pos}`);
+            // Read string until null (0) or newline (10)
+            let end0 = pos + 1;
+            while (end0 < npc0.length && npc0[end0] !== 0) end0++;
+            let end10 = pos + 1;
+            while (end10 < npc0.length && npc0[end10] !== 10) end10++;
+            console.log(`    Null-terminated: "${Buffer.from(npc0.slice(pos + 1, end0)).toString('ascii')}" (end at ${end0})`);
+            console.log(`    Newline-terminated: "${Buffer.from(npc0.slice(pos + 1, end10)).toString('ascii')}" (end at ${end10})`);
+            break;
+        }
+        pos++;
+    }
+}
+
+// Check NPC 1 too
+console.log('\n=== NPC 1 ===');
+const npc1 = result.children.get(1);
+if (npc1) {
+    console.log(`NPC 1: ${npc1.length} bytes`);
+    console.log(`  hex: ${Array.from(npc1.slice(0, 40)).map(b => b.toString(16).padStart(2, '0')).join(' ')}`);
+}
+
+reader.close();
