+/**
+ * Search npc.dat for various NPC names to verify the split + find TD.
+ * Also dump the child IDs from the ref table to check for sparse IDs.
+ */
+import FlatFileCacheReader from '#/cache/osrs/FlatFileCacheReader.js';
+import Packet from '#/io/Packet.js';
+
+const reader = new FlatFileCacheReader('data/osrs-cache-flat');
+
+// Check ref table child IDs
+const configRef = reader.readIndex255(2);
+const npcArchive = configRef.find(e => e.archive === 9);
+console.log(`Archive 9 child count: ${npcArchive?.childCount}`);
+console.log(`First 20 child IDs: ${npcArchive?.childIds.slice(0, 20).join(', ')}`);
+console.log(`Last 20 child IDs: ${npcArchive?.childIds.slice(-20).join(', ')}`);
+console.log(`Max child ID: ${npcArchive?.childIds[npcArchive.childIds.length - 1]}`);
+
+// Check if child IDs are sequential or sparse
+const ids = npcArchive!.childIds;
+let sparse = 0;
+for (let i = 1; i < ids.length; i++) {
+    if (ids[i] !== ids[i-1] + 1) sparse++;
+}
+console.log(`Non-sequential gaps: ${sparse}`);
+
+// Split npc.dat
+const result = reader.readArchive(2, 9);
+if (!result) {
+    console.error('Failed to split npc.dat');
+    process.exit(1);
+}
+console.log(`\nSplit into ${result.children.size} configs`);
+
+// Search for various names
+const searches = ['Tormented', 'demon', 'Demon', 'Hans', 'goblin', 'Goblin', 'guard', 'Guard', 'dragon', 'Dragon'];
+for (const search of searches) {
+    const searchBuf = Buffer.from(search, 'ascii');
+    let count = 0;
+    const foundIds: number[] = [];
+    for (const [npcId, buf] of result.children) {
+        if (buf.length < searchBuf.length) continue;
+        for (let i = 0; i <= buf.length - searchBuf.length; i++) {
+            let match = true;
+            for (let j = 0; j < searchBuf.length; j++) {
+                if (buf[i + j] !== searchBuf[j]) { match = false; break; }
+            }
+            if (match) {
+                count++;
+                if (foundIds.length < 5) foundIds.push(npcId);
+                break;
+            }
+        }
+    }
+    console.log(`"${search}": ${count} NPCs match (first 5 IDs: ${foundIds.join(', ')})`);
+}
+
+// Decode a few known NPCs to verify the decoder works
+console.log('\n=== Decoding sample NPCs ===');
+const sampleIds = [0, 1, 2, 100, 1000, 5000, 10000];
+for (const id of sampleIds) {
+    const buf = result.children.get(id);
+    if (!buf) {
+        console.log(`NPC ${id}: NOT FOUND`);
+        continue;
+    }
+    const p = new Packet(buf);
+    // Manual parse: find op 2 (name)
+    let name = '(no name)';
+    while (p.available > 0) {
+        const op = p.g1();
+        if (op === 0) break;
+        if (op === 2) {
+            name = p.gjstr(0);
+            break;
+        }
+        // Skip unknown op by breaking
+        break;
+    }
+    console.log(`NPC ${id}: ${buf.length}B, name="${name}"`);
+}
+
+reader.close();
