{
  "name": "lostcity-launcher",
  "version": "0.1.0",
  "description": "LostCity OSRS Launcher",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win --x64",
    "build-linux": "electron-builder --linux --x64",
    "build": "electron-builder --win --x64 --linux --x64"
  },
  "build": {
    "appId": "com.lostcity.launcher",
    "productName": "LostCity Launcher",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
